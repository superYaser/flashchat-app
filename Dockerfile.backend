# ============================================================================
# 快闪群聊App - 后端Dockerfile
# ============================================================================

FROM node:18-slim

WORKDIR /app

# 安装依赖
COPY backend/package*.json ./
RUN npm install

# 复制源代码
COPY backend/ ./
COPY shared/ ../shared/

# 创建日志目录
RUN mkdir -p logs

EXPOSE 3000

# 使用node直接运行
CMD ["node", "-r", "ts-node/register/transpile-only", "src/index.ts"]

